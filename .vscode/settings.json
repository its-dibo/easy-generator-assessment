{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": ["source.formatDocument", "source.fixAll.eslint"],
  "files.autoSave": "off",
  "editor.fastScrollSensitivity": 3,
  "editor.mouseWheelZoom": true,
  "editor.showFoldingControls": "always",
  "editor.stablePeek": true,
  "editor.fontSize": 16,
  "diffEditor.codeLens": true,
  "diffEditor.renderSideBySide": false,
  "window.title": "${dirty}${rootName} ${activeEditorShort}",
  "explorer.confirmDelete": false,
  "explorer.decorations.badges": false,
  "git.allowForcePush": true,
  "angular.enable-strict-mode-prompt": false,
  "js/ts.implicitProjectConfig.experimentalDecorators": true,
  "editor.minimap.enabled": false,
  "editor.dragAndDrop": true,
  "eslint.alwaysShowStatus": true,
  "eslint.format.enable": true,
  "eslint.lintTask.enable": true,
  "eslint.lintTask.options": "--fix --config=eslint.config.ts",
  "eslint.probe": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "vue",
    "markdown",
    "json",
    "css",
    "scss"
  ],
  "eslint.useESLintClass": true,
  "cSpell.words": [
    "adsense",
    "appspot",
    "dibo",
    "dind",
    "dompurify",
    "fastify",
    "formly",
    "fsrs",
    "gcloud",
    "hookable",
    "hotjar",
    "hypernate",
    "Laravel",
    "mobarmegeen",
    "nestjs",
    "pgadmin",
    "postback",
    "prerender",
    "primeng",
    "prosemirror",
    "renovate",
    "retrievability",
    "smee",
    "supergroup",
    "supergroups",
    "tiptap",
    "typeorm",
    "upsert"
  ],
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 5,
  "editor.suggest.matchOnWordStartOnly": true,
  "markdown.experimental.updateLinksOnFileMove.enabled": "prompt",
  "workbench.experimental.editSessions.autoStore": "onShutdown",
  "workbench.experimental.editSessions.enabled": true,
  "vscode-open-files-in-directory.maxFiles": 1000,
  "vscode-open-files-in-directory.maxRecursiveDepth": 50,
  "task.allowAutomaticTasks": "on",
  "npm.packageManager": "pnpm",
  "search.exclude": {
    "**/dist": true,
    "docs": true,
    ".nx": true,
    "pnpm-lock.yaml": true,
    "package-lock.json": true,
    "yarn.lock": true
  },
  "files.watcherExclude": {
    ".nx": true,
    "**/.angular": true,
    "**/dist": true,
    "**/node_modules": true,
    "docs": true
  },
  "conventionalCommits.scopes": [
    "cms-backend",
    "cms-ui",
    "github-webhooks",
    "express",
    "ngx-lazy-load",
    "ngx-formly-primeng",
    "ngx-utils",
    "cache",
    "javascript",
    "ngx-formly",
    "ngx-cards-mat",
    "ngx-editor",
    "tiptap-editor",
    "geo",
    "ngx-formly-mat",
    "nodejs",
    "nestjs"
  ],
  "conventionalCommits.autoCommit": true,
  "conventionalCommits.gitmoji": false,
  "conventionalCommits.lineBreak": "\\n",
  "conventionalCommits.promptBody": false,
  "conventionalCommits.promptFooter": false,
  "conventionalCommits.": false,
  "git.enableSmartCommit": true,
  "git.smartCommitChanges": "all",
  "git.postCommitCommand": "none",
  "nxConsole.generateAiAgentRules": true,
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-docker"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "typescript.experimental.useTsgo": false
}
