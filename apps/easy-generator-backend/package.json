{
  "name": "@easy-generator/backend",
  "version": "1.0.0",
  "description": "Generate courses",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "pnpm run build && pnpm run serve",
    "build": "nest build",
    "postbuild": "shx cp package.json .env dist",
    "serve": "node --env-file=.env dist/main.js",
    "preserve": "kill-port ${PORT:-5000} || true"
  },
  "nx": {
    "projectType": "application",
    "targets": {
      "build": {},
      "serve": {}
    }
  },
  "imports": {
    "#*": "./*"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@impactor/nest": "5.0.0",
    "@impactor/nodejs": "3.0.4",
    "@nestjs/common": "^11.1.13",
    "@nestjs/core": "^11.1.13",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "fastify": "^5.7.4",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-fsrs": "^5.2.3",
    "tslib": "^2.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.13",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.11",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "kill-port": "^2.0.1",
    "shx": "^0.4.0",
